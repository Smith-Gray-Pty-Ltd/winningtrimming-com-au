# =============================================================================
# Copy to .env and fill in values — NEVER commit .env
# =============================================================================

# --- Image Versions ---
WORDPRESS_VERSION=6.7-php8.3-apache
MARIADB_VERSION=11
REDIS_VERSION=7-alpine

# --- Database ---
DB_ROOT_PASSWORD=
DB_PASSWORD=

# --- Let's Encrypt ---
ACME_EMAIL=

# --- Redis ---
REDIS_PASSWORD=

# --- WordPress ---
WP_ENVIRONMENT=production
WP_HOME=https://winningtrimming.com.au
WP_SITEURL=https://winningtrimming.com.au
WP_MEMORY_LIMIT=256M

# --- Port (local dev, ignored in production with docker-compose.prod.yml) ---
WP_PORT=8080

# --- Resource Limits (uncomment for production) ---
# DB_MEMORY_LIMIT=512M
# WP_MEMORY_LIMIT_CONTAINER=512M
# WP_CPU_LIMIT=1.0
# REDIS_MEMORY_LIMIT=128M

# --- n8n Integration ---
N8N_WEBHOOK_URL=
N8N_API_KEY=
